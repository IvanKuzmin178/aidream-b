PORT=8080
NODE_ENV=development

# GCP
GCP_PROJECT_ID=aidream-dev
GOOGLE_APPLICATION_CREDENTIALS=  # путь к JSON-ключу service account (см. README шаг 9)
GCP_REGION=us-central1
GCS_BUCKET=aidream-media
CLOUD_TASKS_QUEUE=aidream-pipeline
CLOUD_TASKS_LOCATION=us-central1
BACKEND_URL=http://localhost:8080

# Firebase
FIREBASE_PROJECT_ID=aidream-dev

# Vertex AI
VERTEX_AI_MODEL=veo-2.0-generate-001

# App
FREE_CREDITS=20
MAX_PHOTOS_PER_PROJECT=20
MIN_PHOTOS_PER_PROJECT=5
MAX_CONCURRENT_PROJECTS=3

# CORS
CORS_ORIGIN=http://localhost:3000
